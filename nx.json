{
  "$schema": "https://raw.githubusercontent.com/nrwl/nx/master/packages/nx/schemas/nx-schema.json",
  "release": {
    "projectsRelationship": "fixed",
    "projects": ["packages/*", "!packages/oci"],
    "conventionalCommits": {
      "types": {
        "feat": { "semverBump": "minor", "changelog": true },
        "fix": { "semverBump": "patch", "changelog": true },
        "chore": { "semverBump": "patch", "changelog": true }
      }
    },
    "version": {
      "conventionalCommits": true
    },
    "changelog": {
      "workspaceChangelog": {
        "file": "CHANGELOG.md",
        "createRelease": "github"
      },
      "projectChangelogs": false
    },
    "git": {
      "commit": true,
      "commitMessage": "chore: release {version}",
      "tag": true
    },
    "releaseTag": {
      "pattern": "v{version}"
    }
  },
  "analytics": true
}
