{
  "name": "@xplane/function",
  "version": "1.6.0",
  "type": "module",
  "description": "Crossplane composition function runtime — evaluates inline TypeScript/JavaScript compositions",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/sv-oss/xplane",
    "directory": "packages/function"
  },
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.mts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist bundle .turbo"
  },
  "dependencies": {
    "@crossplane-org/function-sdk-typescript": "0.5.0",
    "@xplane/core": "workspace:*",
    "isomorphic-git": "^1.29.0",
    "oci-client": "^0.0.13",
    "pino": "^10.3.1",
    "tar": "^7.5.16"
  },
  "devDependencies": {
    "@types/tar": "^7.0.87",
    "tsdown": "^0.22.0",
    "typescript": "6.0.3",
    "vitest": "4.1.6"
  }
}
