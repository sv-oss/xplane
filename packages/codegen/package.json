{
  "name": "@xplane/codegen",
  "version": "1.10.1",
  "type": "module",
  "description": "Generate TypeScript types from Crossplane CRD schemas",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sv-oss/xplane",
    "directory": "packages/codegen"
  },
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "xplane-codegen": "./dist/cli.mjs"
  },
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.mts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@apidevtools/json-schema-ref-parser": "^15.3.5",
    "citty": "0.2.2",
    "tar": "^7.5.16",
    "yaml": "2.9.0"
  },
  "devDependencies": {
    "@types/node": "^25.8.0",
    "@types/tar": "^7.0.87",
    "@xplane/oci": "workspace:*",
    "msw": "^2.14.6",
    "tsdown": "^0.22.0",
    "typescript": "6.0.3",
    "vitest": "4.1.6"
  }
}
