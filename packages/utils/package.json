{
  "name": "@xplane/utils",
  "version": "1.4.0",
  "type": "module",
  "description": "CLI and library to watch Crossplane XRs in real time (events, status.xplane, readiness)",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/sv-oss/xplane",
    "directory": "packages/utils"
  },
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "xplane-utils": "./dist/cli.mjs"
  },
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.mts"
    },
    "./render": {
      "import": "./dist/render/index.mjs",
      "types": "./dist/render/index.d.mts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@kubernetes/client-node": "^1.4.0",
    "chalk": "^5.3.0",
    "citty": "0.2.2",
    "log-update": "^7.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.8.0",
    "@vitest/coverage-v8": "4.1.6",
    "tsdown": "^0.22.0",
    "typescript": "6.0.3",
    "vitest": "4.1.6"
  }
}
