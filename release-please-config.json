{
	"$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
	"separate-pull-requests": false,
	"group-pull-request-title-pattern": "chore(main): release ${version}",
	"last-release-sha": "3e5c569ef3c493e9757215ad0b07c86f3bdb1d7e",
	"plugins": [
		{
			"type": "node-workspace",
			"merge": false
		},
		{
			"type": "linked-versions",
			"groupName": "xplane",
			"components": ["core", "function", "codegen"]
		}
	],
	"packages": {
		"packages/core": {
			"release-type": "node",
			"release-as": "0.3.0",
			"component": "core",
			"package-name": "@xplane/core",
			"include-component-in-tag": false
		},
		"packages/function": {
			"release-type": "node",
			"release-as": "0.3.0",
			"component": "function",
			"package-name": "@xplane/function",
			"include-component-in-tag": false
		},
		"packages/codegen": {
			"release-type": "node",
			"release-as": "0.3.0",
			"component": "codegen",
			"package-name": "@xplane/codegen",
			"include-component-in-tag": false
		}
	}
}
