{
	"$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
	"separate-pull-requests": true,
	"plugins": [
		{
			"type": "node-workspace"
		}
	],
	"packages": {
		"packages/core": {
			"release-type": "node",
			"release-as": "0.2.0",
			"component": "core",
			"package-name": "@xplane/core",
			"include-component-in-tag": true
		},
		"packages/function": {
			"release-type": "node",
			"release-as": "0.2.0",
			"component": "function",
			"package-name": "@xplane/function",
			"include-component-in-tag": true
		},
		"packages/codegen": {
			"release-type": "node",
			"release-as": "0.2.0",
			"component": "codegen",
			"package-name": "@xplane/codegen",
			"include-component-in-tag": true
		}
	}
}
